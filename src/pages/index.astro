---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>She works in hotel sales. I build software.</h1>
			<p>This blog sits somewhere in the space between the two.</p>
			<p>
				This blog documents <a href="https://github.com/alvindcastro/groupscout">groupscout</a> —
				a tool I'm building to help her find group lodging leads before anyone else does.
				Construction crews, sports teams, film productions, government contractors — the kind of
				business that never walks in through the front door unless someone goes looking for it first.
			</p>
			<p>
				It's part love project, part learning exercise. I write about what I build, what breaks,
				and what I learn about hotel sales along the way — more than I ever expected to, honestly.
			</p>
			<p>
				This is for anyone interested in early leads, side projects, or learning a new industry
				by building something real.
			</p>
			<p>
				<a href={`${import.meta.env.BASE_URL}blog`}>Read the posts →</a>
			</p>
		</main>
		<Footer />
	</body>
</html>
